# 로컬 API 서버가 사용할 AI 백엔드
# 지원 값: codex-cli, openai
AI_BACKEND=codex-cli

# Codex CLI 실행 명령과 기본 모델
CODEX_BIN=codex
CODEX_MODEL=gpt-5.4
# `.env.example` 를 `.env` 로 복사하면 아래 보조 웹 조사 전용 선택 키도 함께 들어갑니다.
# 장비 메타데이터 수집이나 캠핑장 후기 tip 조사에만 다른 설정을 쓰고 싶을 때 주석을 해제해 덮어씁니다.
# 별도 설정이 없을 때의 기본값:
# - CODEX_METADATA_MODEL: gpt-5.4-mini
# - CODEX_METADATA_REASONING_EFFORT: low
# CODEX_METADATA_MODEL=gpt-5.4-mini
# CODEX_METADATA_REASONING_EFFORT=low

# 선택적 OpenAI 대체 백엔드 설정
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5.2
# 별도 설정이 없을 때 OpenAI 보조 웹 조사 기본값:
# - OPENAI_METADATA_MODEL: gpt-5-mini
# OPENAI_METADATA_MODEL=gpt-5-mini

# 계획 날씨 자동 수집은 Open-Meteo geocoding + forecast API를 직접 사용합니다.
# 별도 API key 나 모델 설정이 필요하지 않습니다.

# 로컬 API 포트
API_PORT=8787

# 선택적 SMTP 메일 발송 설정
# 전체 분석 완료 후 선택한 동행자에게 결과 Markdown을 메일로 보낼 때 사용합니다.
# Gmail / 개인 Google 계정 기준 발급 순서:
# 1. https://myaccount.google.com/security 에서 2단계 인증을 켭니다.
# 2. https://myaccount.google.com/apppasswords 에서 앱 비밀번호를 새로 생성합니다.
# 3. 생성된 16자리 앱 비밀번호를 SMTP_PASS 에 넣습니다.
# 4. 발신 Gmail 주소를 SMTP_USER 와 SMTP_FROM 에 같은 값으로 넣습니다.
# Gmail 기본 권장값 예시:
# - SMTP_HOST=smtp.gmail.com
# - SMTP_PORT=465
# - SMTP_SECURE=true
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP 인증이 필요한 경우 SMTP_USER 와 SMTP_PASS 를 함께 입력합니다.
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
# SMTP_FROM=camping@example.com

# 선택적 웹 API 기본 주소 재정의
VITE_API_BASE_URL=http://localhost:8787

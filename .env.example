# 로컬 API 서버가 사용할 AI 백엔드
# 지원 값: codex-cli, openai
AI_BACKEND=codex-cli

# Codex CLI 실행 명령과 기본 모델
CODEX_BIN=codex
CODEX_MODEL=gpt-5.4
# `.env.example` 를 `.env` 로 복사하면 아래 메타데이터 전용 선택 키도 함께 들어갑니다.
# 메타데이터 수집에만 다른 설정을 쓰고 싶을 때만 주석을 해제해 덮어씁니다.
# 별도 설정이 없을 때의 기본값:
# - CODEX_METADATA_MODEL: gpt-5.4-mini
# - CODEX_METADATA_REASONING_EFFORT: low
# CODEX_METADATA_MODEL=gpt-5.4-mini
# CODEX_METADATA_REASONING_EFFORT=low

# 선택적 OpenAI 대체 백엔드 설정
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5.2
# 별도 설정이 없을 때 OpenAI 메타데이터 수집 기본값:
# - OPENAI_METADATA_MODEL: gpt-5-mini
# OPENAI_METADATA_MODEL=gpt-5-mini

# 로컬 API 포트
API_PORT=8787

# 선택적 웹 API 기본 주소 재정의
VITE_API_BASE_URL=http://localhost:8787

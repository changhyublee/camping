# AI backend used by the local API server
# Supported values: codex-cli, openai
AI_BACKEND=codex-cli

# Codex CLI command and model
CODEX_BIN=codex
CODEX_MODEL=gpt-5.4

# Optional OpenAI fallback backend settings
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-5.2

# Local API port
API_PORT=8787

# Optional web override for the local API base URL
VITE_API_BASE_URL=http://localhost:8787

{
  "name": "camping",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter @camping/api --filter @camping/web run dev",
    "dev:api": "pnpm --filter @camping/api run dev",
    "dev:web": "pnpm --filter @camping/web run dev",
    "backup:data": "tsx scripts/backup-local-data.ts",
    "seed": "tsx scripts/seed-local-data.ts",
    "build": "pnpm -r --if-present run build",
    "typecheck": "pnpm -r --if-present run typecheck",
    "test": "pnpm -r --if-present run test"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}

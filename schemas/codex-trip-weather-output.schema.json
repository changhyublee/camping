{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodexTripWeatherOutput",
  "type": "object",
  "properties": {
    "lookup_status": {
      "type": "string",
      "enum": ["found", "not_found", "failed"]
    },
    "searched_at": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "region": {
      "type": "string"
    },
    "campsite_name": {
      "type": ["string", "null"]
    },
    "start_date": {
      "type": ["string", "null"]
    },
    "end_date": {
      "type": ["string", "null"]
    },
    "summary": {
      "type": ["string", "null"]
    },
    "min_temp_c": {
      "type": ["number", "null"]
    },
    "max_temp_c": {
      "type": ["number", "null"]
    },
    "precipitation": {
      "type": ["string", "null"]
    },
    "search_result_excerpt": {
      "type": ["string", "null"]
    },
    "source": {
      "type": ["string", "null"]
    },
    "google_search_url": {
      "type": ["string", "null"]
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": ["title", "url"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "lookup_status",
    "searched_at",
    "query",
    "region",
    "campsite_name",
    "start_date",
    "end_date",
    "summary",
    "min_temp_c",
    "max_temp_c",
    "precipitation",
    "search_result_excerpt",
    "source",
    "google_search_url",
    "notes",
    "sources"
  ],
  "additionalProperties": false
}

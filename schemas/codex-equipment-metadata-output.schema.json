{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodexEquipmentMetadataOutput",
  "type": "object",
  "properties": {
    "lookup_status": {
      "type": "string",
      "enum": ["found", "not_found", "failed"]
    },
    "searched_at": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "summary": {
      "type": ["string", "null"]
    },
    "product": {
      "type": ["object", "null"],
      "properties": {
        "brand": { "type": ["string", "null"] },
        "official_name": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] }
      },
      "required": ["brand", "official_name", "model"],
      "additionalProperties": false
    },
    "packing": {
      "type": ["object", "null"],
      "properties": {
        "width_cm": { "type": ["number", "null"] },
        "depth_cm": { "type": ["number", "null"] },
        "height_cm": { "type": ["number", "null"] },
        "weight_kg": { "type": ["number", "null"] }
      },
      "required": ["width_cm", "depth_cm", "height_cm", "weight_kg"],
      "additionalProperties": false
    },
    "planning": {
      "type": ["object", "null"],
      "properties": {
        "setup_time_minutes": { "type": ["integer", "null"] },
        "recommended_people": { "type": ["integer", "null"] },
        "capacity_people": { "type": ["integer", "null"] },
        "season_notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "weather_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "required": [
        "setup_time_minutes",
        "recommended_people",
        "capacity_people",
        "season_notes",
        "weather_notes"
      ],
      "additionalProperties": false
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string" }
        },
        "required": ["title", "url"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "lookup_status",
    "searched_at",
    "query",
    "summary",
    "product",
    "packing",
    "planning",
    "sources"
  ],
  "additionalProperties": false
}

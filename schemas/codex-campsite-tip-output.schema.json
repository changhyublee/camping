{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CodexCampsiteTipOutput",
  "type": "object",
  "properties": {
    "lookup_status": {
      "type": "string",
      "enum": ["found", "not_found", "failed"]
    },
    "searched_at": {
      "type": "string"
    },
    "query": {
      "type": "string"
    },
    "campsite_name": {
      "type": "string"
    },
    "region": {
      "type": ["string", "null"]
    },
    "summary": {
      "type": ["string", "null"]
    },
    "tip_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "detail": {
            "type": "string"
          },
          "helpful_for": {
            "type": ["string", "null"]
          }
        },
        "required": ["title", "detail", "helpful_for"],
        "additionalProperties": false
      }
    },
    "best_site_items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "site_name": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "helpful_for": {
            "type": ["string", "null"]
          },
          "caution": {
            "type": ["string", "null"]
          }
        },
        "required": ["site_name", "reason", "helpful_for", "caution"],
        "additionalProperties": false
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        },
        "required": ["title", "url"],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "lookup_status",
    "searched_at",
    "query",
    "campsite_name",
    "region",
    "summary",
    "tip_items",
    "best_site_items",
    "sources"
  ],
  "additionalProperties": false
}
